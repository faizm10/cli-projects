<div class="page-header">
  <h1>Edit Trip</h1>
  <p>Update your trip details</p>
</div>

<div class="card">
  <%= form_with(model: @trip, local: true) do |form| %>
    <% if @trip.errors.any? %>
      <div class="alert alert-danger">
        <h4><%= pluralize(@trip.errors.count, "error") %> prohibited this trip from being saved:</h4>
        <ul>
          <% @trip.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= form.label :country, "Country", class: "form-label" %>
      <%= form.text_field :country, class: "form-control #{'is-invalid' if @trip.errors[:country].any?}", placeholder: "e.g., France, Japan, Australia" %>
      <% if @trip.errors[:country].any? %>
        <div class="invalid-feedback"><%= @trip.errors[:country].first %></div>
      <% end %>
    </div>

    <div class="grid grid-2">
      <div class="form-group">
        <%= form.label :start_date, "Start Date", class: "form-label" %>
        <%= form.date_field :start_date, class: "form-control #{'is-invalid' if @trip.errors[:start_date].any?}" %>
        <% if @trip.errors[:start_date].any? %>
          <div class="invalid-feedback"><%= @trip.errors[:start_date].first %></div>
        <% end %>
      </div>

      <div class="form-group">
        <%= form.label :end_date, "End Date", class: "form-label" %>
        <%= form.date_field :end_date, class: "form-control #{'is-invalid' if @trip.errors[:end_date].any?}" %>
        <% if @trip.errors[:end_date].any? %>
          <div class="invalid-feedback"><%= @trip.errors[:end_date].first %></div>
        <% end %>
      </div>
    </div>

    <div class="form-group">
      <%= form.label :description, "Description (Optional)", class: "form-label" %>
      <%= form.text_area :description, class: "form-control", rows: 4, placeholder: "Add any notes about your trip..." %>
    </div>

    <div class="form-actions">
      <%= form.submit "Update Trip", class: "btn btn-primary" %>
      <%= link_to "Cancel", trip_path(@trip), class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>
