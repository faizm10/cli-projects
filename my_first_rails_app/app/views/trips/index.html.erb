<div class="page-header">
  <h1>Your Trips</h1>
  <p>Plan and manage your travel adventures</p>
</div>

<% if @trips.any? %>
  <div class="grid grid-3">
    <% @trips.each do |trip| %>
      <div class="trip-card">
        <div class="trip-card-header">
          <div class="trip-card-title">🌍 <%= trip.country %></div>
          <div class="trip-card-subtitle">
            <%= trip.start_date.strftime("%b %d") %> - <%= trip.end_date.strftime("%b %d, %Y") %>
          </div>
        </div>
        
        <div class="trip-card-body">
          <div class="trip-meta">
            <span>Duration: <%= trip.duration_days %> days</span>
            <span><%= pluralize(trip.hotels.count, 'hotel') %></span>
          </div>
          
          <% if trip.description.present? %>
            <p class="trip-description"><%= trip.description %></p>
          <% end %>
          
          <div class="trip-actions">
            <%= link_to "View Details", trip_path(trip), class: "btn btn-primary btn-sm" %>
            <%= link_to "Add Hotel", new_trip_hotel_path(trip), class: "btn btn-success btn-sm" %>
            <%= link_to "Edit", edit_trip_path(trip), class: "btn btn-secondary btn-sm" %>
            <%= link_to "Delete", trip_path(trip), 
                method: :delete, 
                data: { confirm: "Are you sure you want to delete this trip?" },
                class: "btn btn-danger btn-sm" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="card">
    <div style="text-align: center; padding: 3rem;">
      <h2>No trips yet!</h2>
      <p>Start planning your next adventure by creating your first trip.</p>
      <%= link_to "Create Your First Trip", new_trip_path, class: "btn btn-primary" %>
    </div>
  </div>
<% end %>

<div style="margin-top: 2rem; text-align: center;">
  <%= link_to "Create New Trip", new_trip_path, class: "btn btn-primary" %>
</div>
